# ============================================================================
# LLM Proxy — 环境变量配置
# 复制此文件为 .env 并修改：cp .env.example .env
# ============================================================================

# --------------------------------------------------------------------------
# 数据库连接 (MySQL 8.0+)
# --------------------------------------------------------------------------
# 数据库和所有表会在首次启动时自动创建，无需手动 CREATE DATABASE。

# MySQL 服务器地址（改为你的实际 MySQL IP 或域名）
DATABASE_HOST=your-db-host

# MySQL 端口
DATABASE_PORT=3306

# 数据库用户名（生产环境建议创建专用用户而非 root）
DATABASE_USER=your-db-user

# 数据库密码（如含特殊字符，用引号包裹）
DATABASE_PASSWORD=your_password

# 数据库名（系统自动创建）
DATABASE_NAME=llm_proxy

# --------------------------------------------------------------------------
# JWT 签名密钥 (SECRET_KEY)
# --------------------------------------------------------------------------
# 这是整个系统的安全基石，用于签发和校验用户登录令牌 (JWT)。
# 工作流程：
#   1. 用户登录 → 服务器用此密钥签名生成 JWT → 返回给客户端
#   2. 客户端后续每次请求带 JWT → 服务器用此密钥验签 → 确认身份
# 安全后果：任何人知道这个值就能伪造任意用户的登录令牌（包括管理员），
#          完全绕过密码。
# 生成方法：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 生产环境必须修改，且绝对不能提交到 git。
SECRET_KEY=change-me-to-a-random-secret-string

# --------------------------------------------------------------------------
# 网络配置
# --------------------------------------------------------------------------

# 管理 API 监听端口（后端 FastAPI，不是代理端口）。
# 前端通过此端口访问管理接口（登录、端口管理等）。
API_PORT=3998

# 前端界面中展示的IP地址，用于生成代理连接地址。
# 用户创建代理端口后，前端会显示：http://<DISPLAY_IP>:3998/<端口号>/v1
# 设置为你的服务器的实际IP或域名，如 192.168.1.100
DISPLAY_IP=your-server-ip

# CORS 允许的前端源地址，逗号分隔。
# 留空则默认仅允许 localhost:3999（开发模式）。
# 生产环境部署时，设置为你的实际域名，例如：
# CORS_ORIGINS=https://proxy.example.com
CORS_ORIGINS=

# --------------------------------------------------------------------------
# 管理员账号 (首次启动时自动创建)
# --------------------------------------------------------------------------
# 如果数据库中不存在此账号，系统会自动创建。已存在则跳过。
# 生产环境务必修改 DEFAULT_ADMIN_PASSWORD。
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# --------------------------------------------------------------------------
# 安全配置
# --------------------------------------------------------------------------

# 是否允许代理目标指向内网地址（localhost、192.168.x.x、10.x.x.x 等）。
# 默认允许（true），方便开发调试和代理内网服务。
# 如需部署到公网，建议设为 false 防止 SSRF 攻击。
ALLOW_INTERNAL_TARGETS=true

# 是否要求新注册用户经管理员审批后才能登录。
# 设为 true → 用户注册后需管理员在后台审批，与旧版行为一致。
# 设为 false（默认）→ 用户注册后立即可以登录使用，无需审批。
REQUIRE_APPROVAL=false

# --------------------------------------------------------------------------
# 性能调优
# --------------------------------------------------------------------------

# 数据库连接池基准连接数。
# SQLAlchemy 维护一个连接池。20 表示始终保持 20 个空闲连接预备。
# 每次数据库查询从池里取一个连接，用完归还。
# 当并发请求超过池大小时：
#   1. 先尝试创建新连接（上限见 DB_MAX_OVERFLOW）
#   2. 达到总上限后，后续请求排队等待（pool_timeout=30 秒超时）
DB_POOL_SIZE=20

# 数据库连接池溢出上限。
# 总最大并发 = DB_POOL_SIZE + DB_MAX_OVERFLOW = 20 + 40 = 60。
# 这意味着最多 60 个线程可以同时操作数据库。
# MySQL 的 max_connections 必须大于此值，否则数据库端会拒绝连接。
DB_MAX_OVERFLOW=40

# 保存交互记录的线程池大小。
# 每次代理拦截到一个请求/响应，会将记录写入 MySQL。
# 这个写入在独立线程中执行，不阻塞代理转发。
# 8 个线程可处理 ~80-100 次写入/秒，对 100+ 并发用户足够。
DB_SAVE_WORKERS=8

# ── 代理日志专用连接池 ──────────────────────────────────
# 与上面的 DB_POOL_SIZE / DB_MAX_OVERFLOW 完全独立。
# 代理每次拦截请求后写日志使用此池，不会与管理接口争抢连接。
# 100 个 SSE 流同时结束 → 写日志通过此池 → 管理接口不受影响。
DB_LOG_POOL_SIZE=10
DB_LOG_MAX_OVERFLOW=20

# 端口→目标URL 缓存 TTL（秒）。
# 缓存到期后下次查询自动从数据库重载全量数据。
# 新建/删除的代理端口最多此秒数后生效。
# 0 表示禁用缓存，每次都查数据库（最准确但最慢）。
PORT_CACHE_TTL=5

# httpx keep-alive 空闲连接数。HTTP/1.1 下，请求完成后连接回
# 池中保持温热，后续请求直接复用，省去 TLS 握手。
# 并发连接数不设上限（max_connections=None），由操作系统文件描述符
# 数量（ulimit -n）自然限制。单个 Linux 服务器轻松支持数万连接。
HTTPX_MAX_KEEPALIVE_CONNECTIONS=100

# ── 响应缓冲 ──────────────────────────────────────────

# 请求体 / 响应体的内存缓冲上限（字节）。
# 流式和非流式路径均使用 SpooledTemporaryFile：
#   小于此值 → 纯内存，零磁盘 I/O
#   超过此值 → 自动溢出到磁盘临时文件
# 默认 10 MB，LLM API 请求/响应体通常远小于此值。
PROXY_BODY_MEMORY_LIMIT=10485760

# ── 后台清理 ──────────────────────────────────────────

# 批量删除请求记录时，每批 DELETE 的行数上限。
# 值越小越不容易锁表，但清理总耗时越长。
CLEANUP_BATCH_SIZE=1000

# 每 N 批输出一次后台清理进度日志。
# 设为 0 禁用进度日志（只输出开始和结束）。
CLEANUP_LOG_INTERVAL=10
